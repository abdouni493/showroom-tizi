generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  username     String   @unique
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN") // ADMIN | WORKER
  workerId     Int?
  createdAt    DateTime @default(now())
}

model Worker {
  id            Int      @id @default(autoincrement())
  fullName      String
  birthday      DateTime?
  idCardNumber  String?
  phone         String
  roleId        Int?
  role          WorkerRole? @relation(fields: [roleId], references: [id])
  paymentType   String   @default("NONE") // DAILY | MONTHLY | NONE
  paymentAmount Float?
  accountEnabled Boolean @default(false)
  email         String?
  username      String?
  startDate     DateTime @default(now())
  createdAt     DateTime @default(now())

  advances WorkerAdvance[]
  absences WorkerAbsence[]
  payments WorkerPayment[]
}

model WorkerRole {
  id          Int      @id @default(autoincrement())
  name        String
  permissions String   @default("{}") // JSON string
  workers     Worker[]
  createdAt   DateTime @default(now())
}

model Showroom {
  id          Int     @id @default(autoincrement())
  logo        String?
  name        String  @default("Mon Showroom")
  description String?
  email       String?
  phone       String?
  address     String?
  nif         String?
  nis         String?
  article     String?
  rc          String?
}

model Supplier {
  id        Int      @id @default(autoincrement())
  fullName  String
  phone     String
  address   String?
  nif       String?
  nis       String?
  article   String?
  rs        String?
  createdAt DateTime @default(now())

  purchases Purchase[]
}

model Client {
  id                 Int      @id @default(autoincrement())
  photo              String?
  firstName          String
  lastName           String
  birthDate          DateTime?
  birthPlace         String?
  gender             String?
  profession         String?
  address            String?
  phonePrimary       String
  phoneSecondary     String?
  email              String?
  docType            String?
  docNumber          String?
  docDeliveryDate    DateTime?
  docDeliveryAddress String?
  docExpiry          DateTime?
  docImage           String?
  nif                String?
  rc                 String?
  nis                String?
  art                String?
  createdAt          DateTime @default(now())

  purchases    Purchase[]
  sales        Sale[]
  carPayments  ClientCarPayment[]
}

model Car {
  id         Int      @id @default(autoincrement())
  images     String   @default("[]") // JSON array of urls
  brand      String
  model      String
  plate      String?
  year       Int?
  color      String?
  fiche      String?
  energy     String   @default("ESSENCE") // ESSENCE | DIESEL | HYBRID | ELECTRIC
  gearbox    String   @default("MANUAL")  // MANUAL | AUTO
  seats      Int?
  mileage    Int?
  vin        String?
  keysCount  Int?
  documents  String   @default("[]") // JSON array of { type, url }
  status     String   @default("AVAILABLE") // AVAILABLE | SOLD | RESERVED
  createdAt  DateTime @default(now())

  purchase            Purchase?
  sales               Sale[]
  expenses            Expense[]
  carPayments         ClientCarPayment[]
  websiteOffer        WebsiteOffer?
  websiteReservations WebsiteReservation[]
}

model Purchase {
  id            Int      @id @default(autoincrement())
  reference     String?
  sourceType    String   @default("SUPPLIER") // SUPPLIER | CLIENT
  supplierId    Int?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  clientId      Int?
  client        Client?  @relation(fields: [clientId], references: [id])
  carId         Int      @unique
  car           Car      @relation(fields: [carId], references: [id])
  purchasePrice Float    @default(0)
  sellingPrice  Float    @default(0)
  amountPaid    Float    @default(0)
  amountRest    Float    @default(0)
  date          DateTime @default(now())
  inspection    String   @default("{}") // JSON
  createdAt     DateTime @default(now())

  payments PurchasePayment[]
}

model PurchasePayment {
  id          Int      @id @default(autoincrement())
  purchaseId  Int
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
}

model Sale {
  id                 Int      @id @default(autoincrement())
  reference          String?
  carId              Int
  car                Car      @relation(fields: [carId], references: [id])
  clientId           Int
  client             Client   @relation(fields: [clientId], references: [id])
  saleType           String   @default("NORMAL") // NORMAL | DEPOSIT
  tvaEnabled         Boolean  @default(false)
  tvaRate            Float?
  reductionType      String   @default("NONE") // NONE | PERCENT | FIXED
  reductionValue     Float?
  totalBeforeTax     Float    @default(0)
  totalAfterTax      Float    @default(0)
  totalAfterReduction Float   @default(0)
  amountPaid         Float    @default(0)
  amountRest         Float    @default(0)
  clientTakeCar      Boolean  @default(true)
  date               DateTime @default(now())
  inspection         String   @default("{}") // JSON
  createdAt          DateTime @default(now())

  payments SalePayment[]
  carPayments ClientCarPayment[]
}

model SalePayment {
  id          Int      @id @default(autoincrement())
  saleId      Int
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
}

model ClientCarPayment {
  id          Int      @id @default(autoincrement())
  carId       Int
  car         Car      @relation(fields: [carId], references: [id])
  clientId    Int
  client      Client   @relation(fields: [clientId], references: [id])
  saleId      Int?
  sale        Sale?    @relation(fields: [saleId], references: [id])
  amount      Float
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
}

model Expense {
  id          Int      @id @default(autoincrement())
  type        String   @default("SHOWROOM") // CAR | SHOWROOM
  carId       Int?
  car         Car?     @relation(fields: [carId], references: [id])
  name        String
  description String?
  amount      Float    @default(0)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model WorkerPayment {
  id          Int      @id @default(autoincrement())
  workerId    Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  month       String?
  date        DateTime @default(now())
  amount      Float
  description String?
  createdAt   DateTime @default(now())

  advances WorkerAdvance[]
  absences WorkerAbsence[]
}

model WorkerAdvance {
  id          Int      @id @default(autoincrement())
  workerId    Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  amount      Float
  date        DateTime @default(now())
  description String?
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  paymentId   Int?
  payment     WorkerPayment? @relation(fields: [paymentId], references: [id])
  createdAt   DateTime @default(now())
}

model WorkerAbsence {
  id          Int      @id @default(autoincrement())
  workerId    Int
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  description String?
  cost        Float    @default(0)
  isPaid      Boolean  @default(false)
  paidAt      DateTime?
  paymentId   Int?
  payment     WorkerPayment? @relation(fields: [paymentId], references: [id])
  createdAt   DateTime @default(now())
}

model WebsiteOffer {
  id           Int      @id @default(autoincrement())
  carId        Int      @unique
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  hidden       Boolean  @default(false)
  isSpecial    Boolean  @default(false)
  specialPrice Float?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
}

model WebsiteReservation {
  id          Int      @id @default(autoincrement())
  carId       Int
  car         Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  clientName  String
  clientPhone String
  status      String   @default("PENDING") // PENDING | ACCEPTED | CANCELLED
  createdAt   DateTime @default(now())
}

model CarDocumentType {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model WebsiteContact {
  id        Int     @id @default(autoincrement())
  facebook  String?
  instagram String?
  tiktok    String?
  maps      String?
  whatsapp  String?
  createdAt DateTime @default(now())
}
